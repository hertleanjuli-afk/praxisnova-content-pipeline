# Gemini API Key für Textgenerierung (kostenlos von aistudio.google.com)
GEMINI_API_KEY=

# Together.ai API Key für Bild-Fallback (optional, kostenlos von api.together.xyz)
# Bildgenerierung nutzt primär Pollinations.ai (kein Key nötig)
# Together.ai FLUX.1-schnell wird als Fallback verwendet wenn Pollinations nicht verfügbar ist
TOGETHER_API_KEY=
